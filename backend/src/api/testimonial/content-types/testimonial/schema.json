{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Customer testimonials shown on homepage and Customers page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "quote": {
      "type": "text",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string"
    },
    "initials": {
      "type": "string",
      "maxLength": 4
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    }
  }
}
